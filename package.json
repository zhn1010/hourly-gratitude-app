{
  "name": "hourly-gratitude-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply gratitude_bot --local",
    "db:migrate:remote": "wrangler d1 migrations apply gratitude_bot --remote",
    "set-webhook": "tsx scripts/set-webhook.ts",
    "sample:poster": "node --import tsx/esm scripts/generate-sample-poster.ts",
    "sample:reactions": "node --import tsx/esm scripts/generate-sample-reactions.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260210.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4",
    "wrangler": "^4.16.1"
  }
}
